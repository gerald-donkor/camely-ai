// Lifecycle state for project metadata.
enum ProjectStatus {
  DRAFT
  ARCHIVED
}

// Core project record owned by a Clerk user.
model Project {
  id             String                @id @default(cuid())
  ownerId        String
  name           String
  description    String?
  status         ProjectStatus         @default(DRAFT)
  canvasJsonPath String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  collaborators  ProjectCollaborator[]
  taskRuns       TaskRun[]
  specs          ProjectSpec[]

  @@index([ownerId])
  @@index([createdAt])
}

// Email-based collaborators associated with a project.
model ProjectCollaborator {
  id        String   @id @default(cuid())
  projectId String
  email     String
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, email])
  @@index([email])
  @@index([projectId, createdAt])
}

// Trigger.dev run ownership for project-scoped background jobs.
model TaskRun {
  id        String   @id @default(cuid())
  runId     String   @unique
  projectId String
  userId    String
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([userId, projectId])
}

// Persistent specification files.
model ProjectSpec {
  id        String   @id @default(cuid())
  projectId String
  filePath  String
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([createdAt])
}
